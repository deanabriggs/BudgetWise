@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container-fluid">

        <a class="navbar-brand" href="/">BudgetWise</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#navMenu" aria-controls="navMenu"
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">
                    <NavLink class="nav-link" href="/dashboard" Match="NavLinkMatch.All">
                        Dashboard
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/accounts">
                        Accounts
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/budgets">
                        Budgets
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/categories">
                        Categories
                    </NavLink>
                </li>

            </ul>

            <AuthorizeView>
                <Authorized>
                    <form method="post"
                          class="d-flex align-items-center"
                          action="/Identity/Account/Logout?returnUrl=/">

                        <button type="submit"
                                class="btn btn-outline-light ms-2">
                            Logout
                        </button>
                    </form>
                </Authorized>

                <NotAuthorized>
                    <a href="/Identity/Account/Login" class="btn btn-outline-light">
                        Login
                    </a>
                </NotAuthorized>
            </AuthorizeView>

        </div>
    </div>
</nav>

<style>
    /* Better focus visibility for accessibility (WCAG 2.1 AA) */
    a:focus, button:focus {
        outline: 3px solid #ffeb3b;
        outline-offset: 3px;
    }
</style>
