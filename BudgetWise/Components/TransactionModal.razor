<EditForm Model="@Transaction" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label>Type</label>
        <select class="form-select" @bind="SelectedType">
            <option value="Income">Income</option>
            <option value="Expense">Expense</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Amount</label>
        <input class="form-control"
               type="number"
               step="0.01"
               @bind-value="DisplayAmount" />
    </div>

    <div class="mb-3">
        <label>Category</label>
        <input class="form-control" @bind="Transaction.Category" />
    </div>

    <div class="mb-3">
        <label>Description</label>
        <input class="form-control" @bind="Transaction.Description" />
    </div>

    <div class="mb-3">
        <label>Date</label>
        <input class="form-control" type="date" @bind="Transaction.Date" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</EditForm>

@code {
    private string SelectedType { get; set; } = "Expense";

    // Displayed amount (always positive)
    private decimal DisplayAmount
    {
        get => Math.Abs(Transaction.Amount);
        set
        {
            if (SelectedType == "Income")
                Transaction.Amount = Math.Abs(value);
            else
                Transaction.Amount = -Math.Abs(value);
        }
    }

    [Parameter] public UserTransaction Transaction { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }

    private async Task HandleValidSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
