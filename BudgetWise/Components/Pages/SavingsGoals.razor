@page "/savings-goals"
@using BudgetWise.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@inject ApplicationDbContext Context
@inject UserManager<User> UserManager
@inject AuthenticationStateProvider AuthProvider

<h3 class="mb-3">Savings Goals</h3>

@if (IsLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else
{
    <button class="btn btn-primary mb-3" @onclick="CreateNewGoal">Add New Goal</button>

    <!-- Create / Edit Form -->
    @if (IsEditing)
    {
        <div class="card mb-4">
            <div class="card-header">
                @(EditingGoal.Id == 0 ? "Add Savings Goal" : "Edit Savings Goal")
            </div>
            <div class="card-body">
                <EditForm Model="@EditingGoal" OnValidSubmit="@SaveGoal">
                    <DataAnnotationsValidator />

                    <div class="mb-2">
                        <label>Name</label>
                        <InputText class="form-control" @bind-Value="EditingGoal.Name" />
                    </div>

                    <div class="mb-2">
                        <label>Target Amount ($)</label>
                        <InputNumber class="form-control" @bind-Value="EditingGoal.TargetAmount" />
                    </div>

                    <div class="mb-2">
                        <label>Current Amount ($)</label>
                        <InputNumber class="form-control" @bind-Value="EditingGoal.CurrentAmount" />
                    </div>

                    <div class="mb-2">
                        <label>Target Date</label>
                        <InputDate class="form-control" @bind-Value="EditingGoal.TargetDate" />
                    </div>

                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="CancelEdit">Cancel</button>
                </EditForm>
            </div>
        </div>
    }

    <!-- List of goals -->
    <div class="card">
        <div class="card-header"><strong>Your Savings Goals</strong></div>
        <div class="card-body">

            @if (Goals.Count == 0)
            {
                <p>No savings goals yet.</p>
            }
            else
            {
                @foreach (var g in Goals)
                {
                    var progress = g.TargetAmount <= 0
                        ? 0
                        : Math.Min(100m, (g.CurrentAmount / g.TargetAmount) * 100m);

                    <div class="mb-3 p-2 border rounded">
                        <div class="d-flex justify-content-between">
                            <strong>@g.Name</strong>
                            <div>
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditGoal(g)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteGoal(g)">Delete</button>
                            </div>
                        </div>

                        <div class="text-muted small">
                            @g.CurrentAmount.ToString("C") of @g.TargetAmount.ToString("C")
                            (@progress.ToString("0")%)
                        </div>

                        <div class="progress">
                            <div class="progress-bar" role="progressbar"
                                 style="width:@progress%">
                            </div>
                        </div>

                        @if (g.TargetDate != null)
                        {
                            <div class="small mt-1">Target Date: @g.TargetDate?.ToString("yyyy-MM-dd")</div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private User? user;
    private bool IsLoading = true;
    private string? ErrorMessage;

    private List<SavingsGoal> Goals = new();

    private bool IsEditing = false;
    private SavingsGoal EditingGoal = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            user = await UserManager.GetUserAsync(auth.User);

            if (user == null)
            {
                ErrorMessage = "User not found.";
                return;
            }

            await LoadGoals();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadGoals()
    {
        if (user == null) return;

        Goals = await Context.SavingsGoals
            .Where(g => g.UserId == user.Id)
            .OrderBy(g => g.Name)
            .ToListAsync();
    }

    private void CreateNewGoal()
    {
        EditingGoal = new SavingsGoal
        {
            UserId = user!.Id,
            CreatedAt = DateTime.Now,
            CurrentAmount = 0
        };
        IsEditing = true;
    }

    private void EditGoal(SavingsGoal goal)
    {
        EditingGoal = new SavingsGoal
        {
            Id = goal.Id,
            Name = goal.Name,
            UserId = goal.UserId,
            TargetAmount = goal.TargetAmount,
            CurrentAmount = goal.CurrentAmount,
            TargetDate = goal.TargetDate,
            CreatedAt = goal.CreatedAt
        };

        IsEditing = true;
    }

    private async Task SaveGoal()
    {
        // Make sure the UserId is always set
        EditingGoal.UserId = user!.Id;

        if (EditingGoal.Id == 0)
        {
            Context.SavingsGoals.Add(EditingGoal);
        }
        else
        {
            Context.SavingsGoals.Update(EditingGoal);
        }

        await Context.SaveChangesAsync();
        await LoadGoals();

        // Reset form
        EditingGoal = new SavingsGoal();
        IsEditing = false;
    }

    private void CancelEdit()
    {
        EditingGoal = new SavingsGoal();
        IsEditing = false;
    }

    private async Task DeleteGoal(SavingsGoal goal)
    {
        Context.SavingsGoals.Remove(goal);
        await Context.SaveChangesAsync();
        await LoadGoals();
    }
}
