@page "/transactions"
@using BudgetWise.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.CodeAnalysis.Elfie.Serialization
@using Microsoft.EntityFrameworkCore
@using BudgetWise.Components.Shared
@using System.IO
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using System.Globalization
@using Microsoft.IdentityModel.Tokens
@attribute [StreamRendering]
@attribute [Authorize]

<PageTitle>Transactions</PageTitle>

@inject ApplicationDbContext Context
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager

<h1 class="mb-4">Transactions</h1>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @ErrorMessage
    </div>
}

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success" role="status">
        @SuccessMessage
    </div>
}

@if (user is null)
{
    <p>You must be logged in to manage transactions.</p>
}
else
{
    <!-- Filters and summary -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Filters</strong>
            <button class="btn btn-sm btn-outline-secondary"
                    @onclick="ClearFilters">
                Clear Filters
            </button>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label" for="filterMonth">Month</label>
                    <select id="filterMonth"
                            class="form-select"
                            @bind="FilterMonth">
                        <option value="">All</option>
                        @foreach (var month in Months)
                        {
                            <option value="@month.Value">@month.Key</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="filterYear">Year</label>
                    <input id="filterYear"
                           class="form-control"
                           type="number"
                           @bind="FilterYear" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="filterCategory">Category</label>
                    <select id="filterCategory"
                            class="form-select"
                            @bind="FilterCategory">
                        <option value="">All Categories</option>
                        @foreach (var category in availableCategories)
                        {
                            <option value="@category.Name">@category.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary w-100"
                            @onclick="ApplyFilters"
                            disabled="@IsBusy">
                        @if (IsBusy)
                        {
                            <span>Loading...</span>
                        }
                        else
                        {
                            <span>Apply Filters</span>
                        }
                    </button>
                </div>
            </div>

            <hr />

            <div class="row text-center">
                <div class="col-md-4 mb-2">
                    <div><strong>Total Income</strong></div>
                    <div class="text-success fw-bold">
                        @TotalIncome.ToString("C")
                    </div>
                </div>
                <div class="col-md-4 mb-2">
                    <div><strong>Total Expenses</strong></div>
                    <div class="text-danger fw-bold">
                        @TotalExpenses.ToString("C")
                    </div>
                </div>
                <div class="col-md-4 mb-2">
                    <div><strong>Net</strong></div>
                    <div class="fw-bold @(NetAmount >= 0 ? "text-success" : "text-danger")">
                        @NetAmount.ToString("C")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Transactions table -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Your Transactions</strong>
            <button class="btn btn-sm btn-outline-primary" @onclick="OpenImportModal">
                Import Transactions
            </button>
            <button class="btn btn-sm btn-outline-primary"
                    @onclick="OpenAddModal">
                Add Transaction
            </button>
        </div>

        <div class="card-body p-0">
            @if (transactions.Count == 0)
            {
                <p class="m-3">
                    No transactions found. Add one using the button above.
                </p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Date</th>
                                <th scope="col">Description</th>
                                <th scope="col">Category</th>
                                <th scope="col" class="text-end">Amount</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in transactions)
                            {
                                <tr>
                                    <td>@t.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@t.Description</td>
                                    <td>@t.Category</td>
                                    <td class="text-end @(t.Amount < 0 ? "text-danger" : "text-success")">
                                        @t.Amount.ToString("C")
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-secondary me-2"
                                                @onclick="@(() => OpenEditModal(t))">
                                            Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="@(() => OpenDeleteModal(t))">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

<!-- Add Modal -->
<SimpleModal IsOpen="@IsAddModalOpen"
             Title="Add Transaction"
             OnClose="CloseAddModal">
    <EditForm Model="@newTransaction" OnValidSubmit="@SaveNewTransaction">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="addDate" class="form-label">Date</label>
            <InputDate id="addDate"
                       class="form-control"
                       @bind-Value="newTransaction.Date" />
        </div>

        <div class="mb-3">
            <label for="addDescription" class="form-label">Description</label>
            <InputText id="addDescription"
                       class="form-control"
                       @bind-Value="newTransaction.Description" />
        </div>

        <div class="mb-3">
            <label for="addCategory" class="form-label">Category</label>
            <InputSelect id="addCategory"
                         class="form-select"
                         @bind-Value="newTransaction.Category">
                <option value="">Select a category</option>
                @foreach (var category in availableCategories)
                {
                    <option value="@category.Name">@category.Name</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label for="addAmount" class="form-label">Amount</label>
            <InputNumber id="addAmount"
                         class="form-control"
                         @bind-Value="newTransaction.Amount" />
            <div class="form-text">
                <strong>Positive</strong> values = income (e.g. <code>1500</code> for paycheck).<br />
                <strong>Negative</strong> values = expenses (e.g. <code>-45.50</code> for groceries).
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <button type="button" class="btn btn-secondary me-2"
                    @onclick="CloseAddModal" disabled="@IsBusy">
                Cancel
            </button>
            <button type="submit" class="btn btn-primary" disabled="@IsBusy">
                @(IsBusy ? "Saving..." : "Save")
            </button>
        </div>
    </EditForm>
</SimpleModal>

<!-- Edit Modal -->
<SimpleModal IsOpen="@IsEditModalOpen"
             Title="Edit Transaction"
             OnClose="CloseEditModal">
    <EditForm Model="@editTransaction" OnValidSubmit="@SaveEditedTransaction">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="editDate" class="form-label">Date</label>
            <InputDate id="editDate"
                       class="form-control"
                       @bind-Value="editTransaction.Date" />
        </div>

        <div class="mb-3">
            <label for="editDescription" class="form-label">Description</label>
            <InputText id="editDescription"
                       class="form-control"
                       @bind-Value="editTransaction.Description" />
        </div>

        <div class="mb-3">
            <label for="editCategory" class="form-label">Category</label>
            <InputSelect id="editCategory"
                         class="form-select"
                         @bind-Value="editTransaction.Category">
                <option value="">Select a category</option>
                @foreach (var category in availableCategories)
                {
                    <option value="@category.Name">@category.Name</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label for="editAmount" class="form-label">Amount</label>
            <InputNumber id="editAmount"
                         class="form-control"
                         @bind-Value="editTransaction.Amount" />
            <div class="form-text">
                Keep using **positive for income**, **negative for expenses**.
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <button type="button" class="btn btn-secondary me-2"
                    @onclick="CloseEditModal" disabled="@IsBusy">
                Cancel
            </button>
            <button type="submit" class="btn btn-primary" disabled="@IsBusy">
                @(IsBusy ? "Saving..." : "Save Changes")
            </button>
        </div>
    </EditForm>
</SimpleModal>

<!-- Delete Modal -->
<SimpleModal IsOpen="@IsDeleteModalOpen"
             Title="Delete Transaction"
             OnClose="CloseDeleteModal">
    @if (deleteTarget is not null)
    {
        <p>Are you sure you want to delete this transaction?</p>
        <ul>
            <li><strong>Date:</strong> @deleteTarget.Date</li>
            <li><strong>Description:</strong> @deleteTarget.Description</li>
            <li><strong>Category:</strong> @deleteTarget.Category</li>
            <li><strong>Amount:</strong> @deleteTarget.Amount.ToString("C")</li>
        </ul>

        <div class="d-flex justify-content-end">
            <button type="button" class="btn btn-secondary me-2"
                    @onclick="CloseDeleteModal" disabled="@IsBusy">
                Cancel
            </button>
            <button type="button" class="btn btn-danger"
                    @onclick="DeleteTransaction" disabled="@IsBusy">
                @(IsBusy ? "Deleting..." : "Delete")
            </button>
        </div>
    }
</SimpleModal>

@* Import CSV Model *@
<SimpleModal IsOpen="@IsImportModalOpen" Title="Import Transactions" OnClose="CloseImportModal" SizeClass="xl">
    <div>
        <InputFile id="fileInput" class="visually-hidden" @key=@InputFileId accept=".csv" OnChange="OnInputFileChange" />
        <label for="fileInput" class="btn btn-secondary">@InputFileMessage</label>

        @if (DisplayImportedRows)
        {
            <button class="btn btn-primary" style="float: right; margin-left: 1em;" @onclick="SaveImportedTransactions">
                Save Import
            </button>
        }
        <button @onclick="CloseImportModal" class="btn btn-secondary" style="float: right; margin-left: 1em;">
            Cancel
        </button>
    </div>

    @if (DisplayImportedRows)
    {
        <p>Does this information look correct?</p>
        <div class="import-container">
            <table id="import-table">
                <tr>
                    <th class="bg-secondary text-white fw-normal">Date</th>
                    <th class="bg-secondary text-white fw-normal">Description</th>
                    <th class="bg-secondary text-white fw-normal">Category</th>
                    <th class="bg-secondary text-white fw-normal">Amount</th>
                </tr>
                @foreach (var transaction in ImportedTransactions)
                {
                    NumberFormatInfo numberFormat = (NumberFormatInfo)CultureInfo.CurrentCulture.NumberFormat.Clone();
                    numberFormat.CurrencyNegativePattern = 1;

                    <tr>
                        <td>@transaction.Date</td>
                        <td>@transaction.Description</td>
                        <td>@transaction.Category</td>
                        <td>@((transaction.Amount > 0 ? "+" : "") + transaction.Amount.ToString("C", numberFormat))</td>
                    </tr>
                }
            </table>
        </div>
    }
    else if (IsBusy)
    {
        <p>Importing data...</p>
    }
</SimpleModal>

<style>
    a:focus, button:focus, input:focus, select:focus {
        outline: 3px solid #ffeb3b;
        outline-offset: 2px;
    }
</style>

@code {
    private User? user;
    private List<UserTransaction> transactions = new();
    private UserTransaction newTransaction = new();
    private UserTransaction editTransaction = new();
    private UserTransaction? deleteTarget;
    private List<Category> availableCategories = new();

    private bool IsAddModalOpen { get; set; }
    private bool IsEditModalOpen { get; set; }
    private bool IsDeleteModalOpen { get; set; }
    private bool IsImportModalOpen { get; set; }

    private int? FilterMonth { get; set; }
    private int? FilterYear { get; set; }
    private string? FilterCategory { get; set; }

    private decimal TotalIncome { get; set; }
    private decimal TotalExpenses { get; set; }
    private decimal NetAmount => TotalIncome + TotalExpenses; // expenses are negative

    private bool IsBusy { get; set; }
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }
    private Guid InputFileId = Guid.NewGuid();
    private List<UserTransaction> ImportedTransactions = new List<UserTransaction>();
    private bool DisplayImportedRows = false;
    private string InputFileMessage = "Choose .csv file";


    private readonly Dictionary<string, int> Months = new()
    {
        { "January", 1 }, { "February", 2 }, { "March", 3 },
        { "April", 4 }, { "May", 5 }, { "June", 6 },
        { "July", 7 }, { "August", 8 }, { "September", 9 },
        { "October", 10 }, { "November", 11 }, { "December", 12 },
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated ?? false)
        {
            user = await UserManager.GetUserAsync(authState.User);
        }

        if (user is null)
        {
            ErrorMessage = "Unable to load the current user. Please log in again.";
            return;
        }

        var now = DateTime.Now;
        FilterMonth = now.Month;
        FilterYear = now.Year;

        await LoadCategoriesAsync();
        await LoadTransactionsAsync();
        ResetNewTransaction();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Refresh categories when navigating to this page to ensure newly added categories are available
        if (user is not null)
        {
            await LoadCategoriesAsync();
        }
    }

    private async Task LoadCategoriesAsync()
    {
        if (user is null) return;

        try
        {
            // Load default categories (UserId is null) and user's custom categories
            availableCategories = await Context.Categories
                .Where(c => c.UserId == null || c.UserId == user.Id)
                .OrderBy(c => c.Name)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            // If Categories table doesn't exist yet, use empty list
            availableCategories = new List<Category>();
        }
    }

    private async Task LoadTransactionsAsync()
    {
        if (user is null)
        {
            transactions.Clear();
            return;
        }

        IsBusy = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var query = Context.UserTransactions
                .Where(t => t.UserId == user.Id)
                .AsQueryable();

            if (FilterMonth is int m && m >= 1 && m <= 12)
                query = query.Where(t => t.Date.Month == m);

            if (FilterYear is int y && y > 0)
                query = query.Where(t => t.Date.Year == y);

            if (!string.IsNullOrWhiteSpace(FilterCategory))
                query = query.Where(t => t.Category == FilterCategory);

            transactions = await query
                .OrderByDescending(t => t.Date)
                .ThenByDescending(t => t.Id)
                .ToListAsync();

            RecalculateTotals();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading transactions: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void RecalculateTotals()
    {
        TotalIncome = transactions.Where(t => t.Amount > 0).Sum(t => t.Amount);
        TotalExpenses = transactions.Where(t => t.Amount < 0).Sum(t => t.Amount);
    }

    private void ResetNewTransaction()
    {
        if (user is null) return;

        newTransaction = new UserTransaction
        {
            UserId = user.Id,
            Date = DateOnly.FromDateTime(DateTime.Today),
            Category = "General",
            Amount = 0
        };
    }

    private void OpenAddModal()
    {
        SuccessMessage = ErrorMessage = null;
        ResetNewTransaction();
        IsAddModalOpen = true;
    }

    private void CloseAddModal() => IsAddModalOpen = false;

    private async Task SaveNewTransaction()
    {
        if (user is null) return;
        IsBusy = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            newTransaction.UserId = user.Id;
            Context.UserTransactions.Add(newTransaction);
            await Context.SaveChangesAsync();

            SuccessMessage = "Transaction added successfully.";
            CloseAddModal();
            await LoadTransactionsAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error saving transaction: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void OpenEditModal(UserTransaction t)
    {
        ErrorMessage = null;
        SuccessMessage = null;

        editTransaction = new UserTransaction
        {
            Id = t.Id,
            UserId = t.UserId,
            Date = t.Date,
            Description = t.Description,
            Category = t.Category,
            Amount = t.Amount
        };

        IsEditModalOpen = true;
    }

    private void CloseEditModal() => IsEditModalOpen = false;

    private async Task SaveEditedTransaction()
    {
        if (user is null) return;
        IsBusy = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            editTransaction.UserId = user.Id;
            Context.UserTransactions.Update(editTransaction);
            await Context.SaveChangesAsync();

            SuccessMessage = "Transaction updated.";
            CloseEditModal();
            await LoadTransactionsAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error updating transaction: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void OpenDeleteModal(UserTransaction t)
    {
        ErrorMessage = null;
        SuccessMessage = null;
        deleteTarget = t;
        IsDeleteModalOpen = true;
    }

    private void CloseDeleteModal()
    {
        IsDeleteModalOpen = false;
        deleteTarget = null;
    }

    private async Task DeleteTransaction()
    {
        if (user is null || deleteTarget is null) return;
        IsBusy = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var existing = await Context.UserTransactions
                .FirstOrDefaultAsync(t => t.Id == deleteTarget.Id && t.UserId == user.Id);

            if (existing is not null)
            {
                Context.UserTransactions.Remove(existing);
                await Context.SaveChangesAsync();
            }

            SuccessMessage = "Transaction deleted.";
            CloseDeleteModal();
            await LoadTransactionsAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error deleting transaction: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void OpenImportModal()
    {
        ResetImportFile();
        IsImportModalOpen = true;
    }

    private void ResetImportFile()
    {
        InputFileId = Guid.NewGuid();
        ImportedTransactions = new List<UserTransaction>();
        DisplayImportedRows = false;
        InputFileMessage = "Choose .csv file";
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        if (user is null) return;
        IsBusy = true; 
        
        DisplayImportedRows = false;
        
        ImportedTransactions = new List<UserTransaction>();

        if (Path.GetExtension(e.File.Name).ToLower() != ".csv")
        {
            ResetImportFile();
            return;
        }

        InputFileMessage = e.File.Name;

        var lines = e.File;
        var maxFileSize = 1024 * 1024 * 100;

        try {
            using var stream = e.File.OpenReadStream(maxFileSize);
            var reader = new StreamReader(stream);

            var currentLine = await reader.ReadLineAsync();

            if (currentLine is null)
                throw new IOException("File has no contents");

            string[] columns = currentLine.Split(",");

            int date = -1;
            int description = -1;
            int category = -1;
            int amount = -1;
            int debit = -1;
            int credit = -1;

            // Pull our column keys from the first row if there are any matches
            for (int i = 0; i < columns.Length; i++)
            {
                var columnName = columns[i].ToLower();

                if (columnName.Contains("date"))
                    date = i;
                else if (columnName == "description")
                    description = i;
                else if (columnName == "category")
                    category = i;
                else if (columnName == "amount")
                    amount = i;
                else if (columnName == "debit")
                    debit = i;
                else if (columnName == "credit")
                    credit = i;
            }

            while (currentLine is not null)
            {
                currentLine = await reader.ReadLineAsync();

                if (currentLine.IsNullOrEmpty() || currentLine is null)
                {
                    break;   
                }
                
                var values = currentLine.Split(",");

                decimal foundAmount = 0;

                if (credit >= 0 && !values[credit].IsNullOrEmpty())
                {
                    Console.WriteLine(("C", credit > 0 ? values[credit] : ""));
                    foundAmount = Decimal.Parse(values[credit]);
                }
                else if (debit >= 0 && !values[debit].IsNullOrEmpty())
                {
                    Console.WriteLine(("D", debit > 0 ? values[debit] : ""));
                    foundAmount = -1 * Math.Abs(Decimal.Parse(values[debit]));
                }
                else if (amount >= 0 && !values[amount].IsNullOrEmpty())
                {
                    Console.WriteLine(("A", amount > 0 ? values[amount] : ""));
                    foundAmount = Decimal.Parse(values[amount]);
                }
                
                var transaction = new UserTransaction {
                    Date = DateOnly.Parse(values[date]),
                    Description = values[description],
                    Category = values[category],
                    Amount = foundAmount,
                };

                ImportedTransactions.Add(transaction);

                // simulate upload delay
                System.Threading.Thread.Sleep(10);
            }
        }
        catch (IOException ex)
        {
            ErrorMessage = $"Error importing transactions: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
            DisplayImportedRows = true;
        }
    }

    private async Task SaveImportedTransactions()
    {
        if (user is null || ImportedTransactions.Count == 0) return;

        try {
            foreach (var transaction in ImportedTransactions)
            {
                transaction.User = user;
                Context.UserTransactions.Add(transaction);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error importing transactions: {ex.Message}";
        }
        finally 
        {
            await Context.SaveChangesAsync();
            CloseImportModal();
        }
    }

    private void CloseImportModal()
    {
        IsImportModalOpen = false;
        DisplayImportedRows = false;
    }

    private async Task ApplyFilters() => await LoadTransactionsAsync();

    private async Task ClearFilters()
    {
        FilterMonth = null;
        FilterYear = null;
        FilterCategory = null;
        await LoadTransactionsAsync();
    }
}
