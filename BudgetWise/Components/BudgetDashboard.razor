@using BudgetWise.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext Context
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager

<div class="transaction-table" style="margin-bottom: 25px;">
    <h3>Totals (@CurrentMonthName @CurrentYear)</h3>

    @if (IsLoading)
    {
        <p>Loading dashboard...</p>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }
    else if (user is null)
    {
        <p>Please log in to see your dashboard.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Total Income</td>
                    <td class="money-positive">@TotalIncome.ToString("C")</td>
                </tr>
                <tr>
                    <td>Total Expenses</td>
                    <td class="money-negative">@TotalExpenses.ToString("C")</td>
                </tr>
                <tr>
                    <td><strong>Balance</strong></td>
                    <td>
                        <strong class="@(Balance >= 0 ? "money-positive" : "money-negative")">
                            @Balance.ToString("C")
                        </strong>
                    </td>
                </tr>
            </tbody>
        </table>
    }
</div>

<!-- Income Budgets Section -->
<div class="transaction-table budgeting-section" style="margin-bottom: 25px;">
    <h3>Income Budgets (@CurrentMonthName @CurrentYear)</h3>

    @if (IsLoading)
    {
        <p>Loading budgets...</p>
    }
    else if (user is null)
    {
    }
    else if (IncomeBudgetSummaries.Count == 0)
    {
        <p>
            No income budgets found for this month.
            Create some budgets on the <a href="/budgets">Budgets page</a>.
        </p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Target</th>
                    <th>Earned</th>
                    <th>Remaining</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in IncomeBudgetSummaries)
                {
                    <tr>
                        <td>@b.Category!.Name</td>
                        <td>@b.Budgeted.ToString("C")</td>
                        <td class="money-positive">@b.Earned.ToString("C")</td>
                        <td class="@(b.Remaining >= 0 ? "money-positive" : "money-negative")">
                            @b.Remaining.ToString("C")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Expense Budgets Section -->
<div class="transaction-table budgeting-section" style="margin-bottom: 25px;">
    <h3>Expense Budgets (@CurrentMonthName @CurrentYear)</h3>

    @if (IsLoading)
    {
        <p>Loading budgets...</p>
    }
    else if (user is null)
    {
    }
    else if (ExpenseBudgetSummaries.Count == 0)
    {
        <p>
            No expense budgets found for this month.
            Create some budgets on the <a href="/budgets">Budgets page</a>.
        </p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Category</th>
                    <th style="text-align: right;">Budgeted</th>
                    <th style="text-align: right;">Spent</th>
                    <th style="text-align: right;">Remaining</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in ExpenseBudgetSummaries)
                {
                    <tr>
                        <td>@b.Category!.Name</td>
                        <td style="text-align: right;">@b.Budgeted.ToString("C")</td>
                        <td style="text-align: right;">@b.Spent.ToString("C")</td>
                        <td style="text-align: right;" class="@(b.Remaining >= 0 ? "money-positive" : "money-negative")">
                            @b.Remaining.ToString("C")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private User? user;

    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }

    private int CurrentMonth { get; set; }
    private int CurrentYear { get; set; }
    private string CurrentMonthName => new DateTime(CurrentYear, CurrentMonth, 1).ToString("MMMM");

    private decimal TotalIncome { get; set; }
    private decimal TotalExpensesRaw { get; set; }
    private decimal TotalExpenses => Math.Abs(TotalExpensesRaw);
    private decimal Balance => TotalIncome + TotalExpensesRaw;

    private List<BudgetSummary> IncomeBudgetSummaries { get; set; } = new();
    private List<BudgetSummary> ExpenseBudgetSummaries { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var today = DateTime.Today;
            CurrentMonth = today.Month;
            CurrentYear = today.Year;

            var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();

            if (!auth.User.Identity?.IsAuthenticated ?? false)
            {
                user = null;
                IsLoading = false;
                return;
            }

            user = await UserManager.GetUserAsync(auth.User);

            if (user == null)
            {
                ErrorMessage = "Unable to load the user.";
                return;
            }

            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadDashboardAsync()
    {
        if (user == null) return;

        // INCOME
        TotalIncome = await Context.Incomes
            .Where(i => i.UserId == user.Id &&
                        i.Date.Month == CurrentMonth &&
                        i.Date.Year == CurrentYear)
            .SumAsync(i => i.Amount);

        // EXPENSES - use category type, not amount sign
        var expenseTransactions = await Context.UserTransactions
            .Include(t => t.Category)
            .Where(t => t.UserId == user.Id &&
                        t.Category != null &&
                        !t.Category.IsIncome &&
                        t.Date.Month == CurrentMonth &&
                        t.Date.Year == CurrentYear)
            .ToListAsync();
        
        TotalExpensesRaw = -expenseTransactions.Sum(t => t.Amount);

        // BUDGETS FOR THIS MONTH
        var budgets = await Context.Budgets
            .Include(b => b.Category)
            .Where(b => b.UserId == user.Id &&
                        b.Month == CurrentMonth &&
                        b.Year == CurrentYear)
            .ToListAsync();

        var transactions = await Context.UserTransactions
            .Include(t => t.Category)
            .Where(t => t.UserId == user.Id &&
                        t.Date.Month == CurrentMonth &&
                        t.Date.Year == CurrentYear)
            .ToListAsync();

        // Separate into income and expense budgets
        var incomeBudgets = budgets.Where(b => b.Category != null && b.Category.IsIncome).ToList();
        var expenseBudgets = budgets.Where(b => b.Category != null && !b.Category.IsIncome).ToList();

        // Calculate income budget summaries (track earned vs target)
        IncomeBudgetSummaries = incomeBudgets
            .Select(b =>
            {
                var earned = transactions
                    .Where(t => t.CategoryId == b.Category!.Id && t.Category != null && t.Category.IsIncome)
                    .Sum(t => t.Amount);

                var remaining = b.MonthlyLimit - earned;

                return new BudgetSummary
                {
                    Category = b.Category!,
                    Budgeted = b.MonthlyLimit,
                    Earned = earned,
                    Spent = 0, // Not used for income budgets
                    Remaining = remaining
                };
            })
            .OrderBy(b => b.Category!.Name)
            .ToList();

        // Calculate expense budget summaries (track spent vs limit)
        ExpenseBudgetSummaries = expenseBudgets
            .Select(b =>
            {
                var spent = transactions
                    .Where(t => t.CategoryId == b.Category!.Id && t.Category != null && !t.Category.IsIncome)
                    .Sum(t => t.Amount);

                var remaining = b.MonthlyLimit - spent;

                return new BudgetSummary
                {
                    Category = b.Category!,
                    Budgeted = b.MonthlyLimit,
                    Earned = 0, // Not used for expense budgets
                    Spent = spent,
                    Remaining = remaining
                };
            })
            .OrderBy(b => b.Category!.Name)
            .ToList();
    }

    private class BudgetSummary
    {
        public Category? Category { get; set; }
        public decimal Budgeted { get; set; }
        public decimal Earned { get; set; } // For income budgets
        public decimal Spent { get; set; } // For expense budgets
        public decimal Remaining { get; set; }
    }
}
