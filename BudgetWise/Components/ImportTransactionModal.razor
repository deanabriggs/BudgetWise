@rendermode InteractiveServer
@using BudgetWise.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.CodeAnalysis.Elfie.Serialization
@using Microsoft.EntityFrameworkCore
@using BudgetWise.Components.Shared
@using System.IO
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using System.Globalization
@using Microsoft.IdentityModel.Tokens
@inject ApplicationDbContext Context
@attribute [StreamRendering]
@attribute [Authorize]

<button onclick="@OpenImportModal" aria-label="Import button" class="@ButtonClass">
    @ButtonText
</button>

@* Import CSV Model *@
<SimpleModal IsOpen="@IsImportModalOpen" Title="Import Transactions" OnClose="CloseImportModal" SizeClass="lg">
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@ErrorMessage</div>
    }

    <div class="pb-3 row d-flex justify-content-between">
        <div class="col-md-4 col-6">
            <InputFile id="fileInput" class="visually-hidden" @key=@InputFileId accept=".csv" OnChange="OnInputFileChange" />
            <label for="fileInput" class="btn btn-outline-secondary text-truncate w-100">@InputFileMessage</label>
        </div>

        <div class="col-lg-3 col-6 d-flex justify-content-right">
            @if (DisplayImportedRows)
            {
                <button class="btn btn-outline-primary w-50 me-1" @onclick="SaveImportedTransactions">
                    Save
                </button>
                <button @onclick="CloseImportModal" class="btn btn-outline-secondary w-50 ms-1">
                    Cancel
                </button>
            }
            else
            {
                <button @onclick="CloseImportModal" class="btn btn-outline-secondary ms-auto ms-1">
                    Cancel
                </button>
            }
        </div>
    </div>

    @if (DisplayImportedRows)
    {
        <div class="import-container">
            @if (ImportedTransactions.Count == 0)
            {
                <p>No matching transactions.</p>
            }
            else
            {
                @foreach (var t in ImportedTransactions)
                {
                    <TransactionDisplay User="@User" DontShowDelete=true Transaction="@t" Categories="@UserCategories" Accounts="@UserAccounts" Callback="@OnTransactionDisplayChanged" />
                }
            }
        </div>
    }
    else if (IsBusy)
    {
        <p>Importing data...</p>
    }
</SimpleModal>

@code {
    [Parameter]
    public required User User { get; set; }

    [Parameter]
    public required string ButtonText { get; set; }

    [Parameter]
    public required string ButtonClass { get; set; }

    [Parameter]
    public required Account Account { get; set ;}

    [Parameter]
    public required List<Category> UserCategories { get; set; }

    [Parameter]
    public required List<Account> UserAccounts { get; set; }

    private bool IsImportModalOpen { get; set; }
    private Guid InputFileId = Guid.NewGuid();
    private List<UserTransaction> ImportedTransactions = new List<UserTransaction>();
    private bool DisplayImportedRows = false;
    private string InputFileMessage = "Choose .csv file";
    private bool IsBusy = false;
    private string? ErrorMessage { get; set; }


    private void OpenImportModal()
    {
        ResetImportFile();
        IsImportModalOpen = true;
    }

    private void ResetImportFile()
    {
        InputFileId = Guid.NewGuid();
        ImportedTransactions = new List<UserTransaction>();
        DisplayImportedRows = false;
        InputFileMessage = "Choose .csv file";
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        IsBusy = true; 
        
        DisplayImportedRows = false;
        
        ImportedTransactions = new List<UserTransaction>();

        if (Path.GetExtension(e.File.Name).ToLower() != ".csv")
        {
            ResetImportFile();
            return;
        }

        InputFileMessage = e.File.Name;

        var lines = e.File;
        var maxFileSize = 1024 * 1024 * 100;

        var existingCategories = await Context.Categories.Where(t => t.UserId == User.Id).ToListAsync();
            HashSet<string> categories = new HashSet<string>();

        // Add all categories to the categories set by name
        foreach (var category in existingCategories)
        {
            if (!categories.Contains(category.Name))
            {
                categories.Add(category.Name);
            }
        }

        try {
            using var stream = e.File.OpenReadStream(maxFileSize);
            var reader = new StreamReader(stream);

            var currentLine = await reader.ReadLineAsync();

            if (currentLine is null)
                throw new IOException("File has no contents");

            string[] columns = currentLine.Split(",");

            int date = -1;
            int source = -1;
            int description = -1;
            int category = -1;
            int amount = -1;
            int debit = -1;
            int credit = -1;

            // Pull our column keys from the first row if there are any matches
            for (int i = 0; i < columns.Length; i++)
            {
                var columnName = columns[i].ToLower();

                if (columnName.Contains("date"))
                    date = i;
                else if (columnName == "source" || columnName == "merchant" || columnName == "vendor" || columnName == "payee")
                    source = i;
                else if (columnName == "description")
                    description = i;
                else if (columnName == "category")
                    category = i;
                else if (columnName == "amount")
                    amount = i;
                else if (columnName == "debit")
                    debit = i;
                else if (columnName == "credit")
                    credit = i;
            }

            while (currentLine is not null)
            {
                currentLine = await reader.ReadLineAsync();

                if (currentLine.IsNullOrEmpty() || currentLine is null)
                {
                    break;   
                }
                
                var values = currentLine.Split(",");

                decimal foundAmount = 0;

                if (credit >= 0 && !values[credit].IsNullOrEmpty())
                {
                    foundAmount = Decimal.Parse(values[credit]);
                }
                else if (debit >= 0 && !values[debit].IsNullOrEmpty())
                {
                    foundAmount = -1 * Math.Abs(Decimal.Parse(values[debit]));
                }
                else if (amount >= 0 && !values[amount].IsNullOrEmpty())
                {
                    foundAmount = Decimal.Parse(values[amount]);
                }

                string categoryStr = category > 0 && values.Length > category ? values[category] : "Uncategorized";

                if (!categories.Contains(categoryStr))
                {
                    categories.Add(categoryStr);

                    var newCategory = new Category
                    {
                        UserId = User.Id,
                        Name = categoryStr,
                        IsDefault = false,
                    }; 

                    existingCategories.Add(newCategory);
                    Context.Categories.Add(newCategory);
                }

                var foundCategory = existingCategories.Where(c => 
                    (categoryStr.Contains(c.Name) || c.Name == categoryStr) 
                    && c.UserId == User.Id).FirstOrDefault();

                if (foundCategory is not null)
                {
                    UserTransaction? transaction = new UserTransaction {
                        Date = DateOnly.Parse(values[date]),
                        Source = source >= 0 && values.Length > source ? values[source] : null,
                        Description = description >= 0 && values.Length > description ? values[description] : null,
                        Category = foundCategory,
                        Amount = foundAmount,
                        AccountId = Account.Id,
                        Account = Account,
                    };

                    ImportedTransactions.Add(transaction);
                }
                else {
                    throw new IOException("Could not find any categories");
                }

                // simulate upload delay
                @* System.Threading.Thread.Sleep(10); *@
            }
        }
        catch (IOException ex)
        {
            ErrorMessage = $"Error importing transactions: {ex.Message}";
        }
        finally
        {
            await Context.SaveChangesAsync();
            StateHasChanged();
            IsBusy = false;
            DisplayImportedRows = true;
        }
    }

    private async Task SaveImportedTransactions()
    {
        if (User is null || ImportedTransactions.Count == 0) return;

        ErrorMessage = null;

        try {

            foreach (var transaction in ImportedTransactions)
            {
                // Ensure CategoryId is set from Category navigation property if needed
                if (transaction.CategoryId == 0 && transaction.Category != null)
                {
                    transaction.CategoryId = transaction.Category.Id;
                }

                // Create new transaction entity without navigation properties to avoid tracking conflicts
                var transactionToAdd = new UserTransaction
                {
                    UserId = User.Id,
                    AccountId = transaction.AccountId,
                    CategoryId = transaction.CategoryId,
                    Date = transaction.Date,
                    Source = transaction.Source,
                    Description = transaction.Description,
                    Amount = transaction.Amount
                };

                Context.UserTransactions.Add(transactionToAdd);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error importing transactions: {ex.Message}";
        }
        finally 
        {
            await Context.SaveChangesAsync();
            StateHasChanged();
            CloseImportModal();
        }
    }

    private void CloseImportModal()
    {
        IsImportModalOpen = false;
        DisplayImportedRows = false;
    }

    // Refresh page when quick transaction is modified
    private Task OnTransactionDisplayChanged()
    {
        StateHasChanged();
        return Task.CompletedTask;
    }
}