@page "/categories"
@using BudgetWise.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.Threading.Tasks
@attribute [StreamRendering]
@attribute [Authorize]

<PageTitle>Categories</PageTitle>

@inject ApplicationDbContext Context
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager

<h1 class="mb-4">Categories</h1>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger" role="alert">@ErrorMessage</div>
}

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success" role="status">@SuccessMessage</div>
}

@if (user is null)
{
    <p>You must be logged in to manage categories.</p>
}
else
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>All Categories</strong>
            <button class="btn btn-sm btn-outline-primary" @onclick="StartCreate">
                Add Category
            </button>
        </div>
        <div class="card-body p-0">
            @if (incomeCategories.Count == 0 && expenseCategories.Count == 0)
            {
                <p class="m-3">
                    No categories yet. Add one above to get started.
                </p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Category</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (incomeCategories.Count > 0)
                            {
                                <tr class="table-secondary">
                                    <td colspan="2"><strong>Income Categories</strong></td>
                                </tr>
                                @foreach (var cat in incomeCategories)
                                {
                                    <tr>
                                        <td>
                                            @cat.Name
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-secondary me-2"
                                                @onclick="() => StartEdit(cat)">
                                                Edit
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => ConfirmDelete(cat)">
                                                Delete
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            @if (expenseCategories.Count > 0)
                            {
                                <tr class="table-secondary">
                                    <td colspan="2"><strong>Expense Categories</strong></td>
                                </tr>
                                @foreach (var cat in expenseCategories)
                                {
                                    <tr>
                                        <td>
                                            @cat.Name
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-secondary me-2"
                                                @onclick="() => StartEdit(cat)">
                                                Edit
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => ConfirmDelete(cat)">
                                                Delete
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

<SimpleModal IsOpen="@IsAddOpen" Title="@FormTitle" OnClose="CloseModals">
    <EditForm Model="@editCategory" OnValidSubmit="@SaveCategory">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger mb-3" />
        
        <div class="mb-3">
            <label for="category-name" class="form-label">Category Name</label>
            <InputText class="form-control" id="category-name" placeholder="Category Name" @bind-Value="@editCategory.Name" />
            <ValidationMessage For="@(() => editCategory.Name)" />
        </div>

        <div class="mb-3">
            <label for="category-type" class="form-label">Category Type</label>
            <InputSelect id="category-type" class="form-select" @bind-Value="@editCategory.IsIncome">
                <option value="false">Expense</option>
                <option value="true">Income</option>
            </InputSelect>
        </div>

        <div class="d-flex justify-content-end">
            <button type="button" class="btn btn-secondary me-2" @onclick="CloseModals" disabled="@IsBusy">
                Cancel
            </button>
            <button type="submit" class="btn btn-primary" disabled="@IsBusy">
                @(IsBusy ? "Saving..." : "Save")
            </button>
        </div>
    </EditForm>
</SimpleModal>

<SimpleModal IsOpen="@IsEditing" Title="@FormTitle" OnClose="CloseModals">
    <EditForm Model="@editCategory" OnValidSubmit="@SaveCategory">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger mb-3" />
        
        <div class="mb-3">
            <label for="category-name-edit" class="form-label">Category Name</label>
            <InputText class="form-control" id="category-name-edit" placeholder="Category Name" @bind-Value="@editCategory.Name" />
            <ValidationMessage For="@(() => editCategory.Name)" />
        </div>

        <div class="mb-3">
            <label for="category-type-edit" class="form-label">Category Type</label>
            <InputSelect id="category-type-edit" class="form-select" @bind-Value="@editCategory.IsIncome">
                <option value="false">Expense</option>
                <option value="true">Income</option>
            </InputSelect>
        </div>

        <div class="d-flex justify-content-end">
            <button type="button" class="btn btn-secondary me-2" @onclick="CloseModals" disabled="@IsBusy">
                Cancel
            </button>
            <button type="submit" class="btn btn-primary" disabled="@IsBusy">
                @(IsBusy ? "Saving..." : "Save")
            </button>
        </div>
    </EditForm>
</SimpleModal>

@code {
    private User? user;
    private List<Category> incomeCategories = new();
    private List<Category> expenseCategories = new();
    private Category editCategory = new();

    private string FormTitle { get; set; } = "Add New Category";
    private bool IsEditing { get; set; }
    private bool IsBusy { get; set; }
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }

    private bool IsAddOpen = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            user = await UserManager.GetUserAsync(authState.User);
        }

        if (user is null)
        {
            ErrorMessage = "Unable to load user.";
            return;
        }

        await EnsureDefaultCategoriesAsync();
        await LoadCategoriesAsync();
    }

    private async Task EnsureDefaultCategoriesAsync()
    {
        // Only create default categories if NO default categories exist at all
        // This prevents recreating categories that users have intentionally deleted
        var hasAnyDefaults = await Context.Categories
            .AnyAsync(c => c.IsDefault && c.UserId == null);

        // If default categories already exist (even if some were deleted), don't recreate them
        if (hasAnyDefaults)
        {
            return;
        }

        // Only create default categories if this is the first time (no defaults exist)
        var existingNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        // Create expense categories
        foreach (var categoryName in DefaultCategories.ExpenseCategoryNames)
        {
            if (!existingNames.Contains(categoryName))
            {
                Context.Categories.Add(new Category
                {
                    Name = categoryName,
                    IsDefault = true,
                    IsIncome = false,
                    UserId = null // Default categories are available to all users
                });
                existingNames.Add(categoryName);
            }
        }

        // Create income categories
        foreach (var categoryName in DefaultCategories.IncomeCategoryNames)
        {
            if (!existingNames.Contains(categoryName))
            {
                Context.Categories.Add(new Category
                {
                    Name = categoryName,
                    IsDefault = true,
                    IsIncome = true,
                    UserId = null // Default categories are available to all users
                });
                existingNames.Add(categoryName);
            }
        }

        try
        {
            await Context.SaveChangesAsync();
        }
        catch (DbUpdateException)
        {
            // Ignore if categories already exist (race condition)
        }
    }

    private async Task LoadCategoriesAsync()
    {
        if (user is null) return;

        // Load all categories: default categories (available to all users) and user's custom categories
        var defaults = await Context.Categories
            .Where(c => c.IsDefault && c.UserId == null)
            .ToListAsync();

        var custom = await Context.Categories
            .Where(c => !c.IsDefault && c.UserId == user.Id)
            .ToListAsync();

        var allCategories = defaults.Concat(custom).ToList();

        // Separate into income and expense categories, each alphabetized
        incomeCategories = allCategories
            .Where(c => c.IsIncome)
            .OrderBy(c => c.Name)
            .ToList();

        expenseCategories = allCategories
            .Where(c => !c.IsIncome)
            .OrderBy(c => c.Name)
            .ToList();
    }

    private void StartCreate()
    {
        IsAddOpen = true;
        IsEditing = false;
        FormTitle = "Add New Category";
        SuccessMessage = ErrorMessage = null;

        editCategory = new Category
        {
            UserId = user!.Id,
            Name = "",
            IsDefault = false,
            IsIncome = false // Default to expense category
        };
    }

    private void StartEdit(Category c)
    {
        IsEditing = true;
        IsAddOpen = true;
        FormTitle = $"Edit Category – {c.Name}";
        SuccessMessage = ErrorMessage = null;

        editCategory = c;
    }

    private async Task SaveCategory()
    {
        if (user is null)
        {
            ErrorMessage = "You must be logged in to save a category.";
            return;
        }

        IsBusy = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            // Trim and validate name
            editCategory.Name = editCategory.Name?.Trim() ?? "";
            if (string.IsNullOrWhiteSpace(editCategory.Name))
            {
                ErrorMessage = "Category name cannot be empty.";
                IsBusy = false;
                return;
            }

            // Check for duplicate names (case-insensitive)
            // Users can have custom categories with any name, but cannot duplicate:
            // - Another custom category of theirs
            // - A default category name (case-insensitive)
            // When editing a default category, check against other default categories
            var existing = await Context.Categories
                .FirstOrDefaultAsync(c => 
                    c.Name.ToLower() == editCategory.Name.ToLower() &&
                    c.Id != editCategory.Id &&
                    ((editCategory.IsDefault && c.IsDefault && c.UserId == null) ||
                     (!editCategory.IsDefault && editCategory.UserId == user.Id && 
                      ((c.UserId == user.Id && !c.IsDefault) || (c.IsDefault && c.UserId == null)))));

            if (existing != null)
            {
                ErrorMessage = "A category with this name already exists.";
                IsBusy = false;
                return;
            }

            if (editCategory.Id == 0)
            {
                // New category - always custom for users
                editCategory.UserId = user.Id;
                editCategory.IsDefault = false;
                Context.Categories.Add(editCategory);
            }
            else
            {
                // Update existing category
                var existingCategory = await Context.Categories
                    .FirstOrDefaultAsync(c => c.Id == editCategory.Id);

                if (existingCategory == null)
                {
                    ErrorMessage = "Category not found.";
                    IsBusy = false;
                    return;
                }

                // Allow editing default categories (but they remain defaults)
                existingCategory.Name = editCategory.Name;
            }

            await Context.SaveChangesAsync();
            await LoadCategoriesAsync();

            SuccessMessage = IsEditing ? "Category updated!" : "Category added!";
            StartCreate();
        }
        catch (DbUpdateException)
        {
            ErrorMessage = "A category with this name already exists.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error saving: {ex.Message}";
        }
        finally
        {
            IsAddOpen = false;
            IsBusy = false;
        }
    }

    private void CancelEdit()
    {
        StartCreate();
    }

    private async Task ConfirmDelete(Category c)
    {
        if (user is null)
        {
            ErrorMessage = "You must be logged in to delete a category.";
            return;
        }

        // Allow deleting any category (default or custom)
        // For default categories, verify they exist and can be deleted
        // For custom categories, verify they belong to the current user
        if (!c.IsDefault && c.UserId != user.Id)
        {
            ErrorMessage = "You can only delete your own categories.";
            return;
        }

        try
        {
            // Check if category is used in transactions or budgets
            // For default categories, check across all users
            // For custom categories, check only for the current user
            var usedInTransactions = c.IsDefault
                ? await Context.UserTransactions.AnyAsync(t => t.CategoryId == c.Id)
                : await Context.UserTransactions.AnyAsync(t => t.UserId == user.Id && t.CategoryId == c.Id);

            var usedInBudgets = c.IsDefault
                ? await Context.Budgets.AnyAsync(b => b.CategoryId == c.Id)
                : await Context.Budgets.AnyAsync(b => b.UserId == user.Id && b.CategoryId == c.Id);

            if (usedInTransactions || usedInBudgets)
            {
                ErrorMessage = $"Cannot delete category '{c.Name}' because it is used in transactions or budgets. Please update or delete those first.";
                return;
            }

            Context.Categories.Remove(c);
            await Context.SaveChangesAsync();

            SuccessMessage = "Category deleted.";
            await LoadCategoriesAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error deleting: {ex.Message}";
        }
    }


    private async Task CloseModals()
    {
        IsAddOpen = false;
        IsEditing = false;

        Context.ChangeTracker.Clear();

        await LoadCategoriesAsync();
    }
}

