@rendermode InteractiveServer
@page "/"
@using Microsoft.JSInterop
@using BudgetWise.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.EntityFrameworkCore.Storage

@inject ApplicationDbContext Context
@inject UserManager<User> UserManager
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="mb-3" style="border: none !important;">
    <h1 class="mb-0" style="border: none !important; outline: none !important;">Welcome to BudgetWise</h1>
</div>

@if (IsLoading)
{
    <p>Loading dashboard...</p>
}
else if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
else if (user is null)
{
    <div class="alert alert-info">
        You must be logged in to see your dashboard.
        <a href="/Identity/Account/Login">Log in</a>
        or
        <a href="/Identity/Account/Register">create an account</a>.
    </div>
}
else
{
    <!-- Motivational message -->
    <div class="row mb-3">
        <div class="col-md-12">
            @if (!string.IsNullOrWhiteSpace(MotivationalMessage))
            {
                <div
                    class="alert @(Balance == 0 ? "alert-warning" : (Balance > 0 ? "alert-success" : "alert-danger")) py-2 px-3 mb-0 small">
                    @MotivationalMessage
                </div>
            }
        </div>
    </div>

    <!-- KPI Row -->
    <div class="row g-3 mb-4 d-md-flex">
        <!-- Income -->
        <div class="col-md-4 flex-fill">
            <div class="card shadow-sm kpi-card kpi-clickable"
                 @onclick="@(() => NavigateTo("/budgets"))"
                 style="cursor:pointer;">
                <div class="card-body">
                    <div class="kpi-label">Income (this month)</div>
                    <div class="kpi-value text-success">@TotalIncome.ToString("C")</div>
                    @if (TotalBudgetedIncome > 0)
                    {
                        var incomeProgress = Math.Min(100m, (TotalIncome / TotalBudgetedIncome) * 100m);
                        <div class="mt-2">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Budget: @TotalBudgetedIncome.ToString("C")</span>
                                <span>@incomeProgress.ToString("0")%</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-success" aria-label="progress bar" role="progressbar" style="width: @incomeProgress%"></div>
                            </div>
                        </div>
                    }
                    @if (LastMonthIncome != 0)
                    {
                        <div class="kpi-change @(IncomeChange >= 0 ? "text-success" : "text-danger") mt-2">
                            <span>
                                @(IncomeChange >= 0 ? "▲" : "▼")
                                @Math.Abs(IncomeChange).ToString("C")
                                vs last month
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Expenses -->
        <div class="col-md-4 d-md-flex">
            <div class="card shadow-sm kpi-card kpi-clickable flex-fill"
                 @onclick="@(() => NavigateTo("/accounts"))"
                 style="cursor:pointer;">
                <div class="card-body">
                    <div class="kpi-label">Expenses (this month)</div>
                    <div class="kpi-value text-danger">@TotalExpensesDisplay.ToString("C")</div>
                    @if (TotalBudgetedExpenses > 0)
                    {
                        var expenseProgress = Math.Min(100m, (TotalExpensesDisplay / TotalBudgetedExpenses) * 100m);
                        <div class="mt-2">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Budget: @TotalBudgetedExpenses.ToString("C")</span>
                                <span>@expenseProgress.ToString("0")%</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-danger" aria-label="progress bar" role="progressbar"
                                    style="width: @expenseProgress%"></div>
                            </div>
                        </div>
                    }
                    @if (LastMonthExpensesDisplay != 0)
                    {
                        <div class="kpi-change @(ExpenseChange <= 0 ? "text-success" : "text-danger") mt-2">
                            <span>
                                @(ExpenseChange <= 0 ? "▼" : "▲")
                                @Math.Abs(ExpenseChange).ToString("C")
                                vs last month
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Balance -->
        <div class="col-md-4 d-md-flex">
            <div class="card shadow-sm kpi-card flex-fill">
                <div class="card-body">
                    <div class="kpi-label">Current Profit/Loss (this month)</div>
                    <div class="kpi-value @(Balance >= 0 ? "text-success" : "text-danger")">
                        @Balance.ToString("C")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Budgeting + Net Worth + Quick Add -->
    <div class="row g-3 mb-4">
        <!-- Budgeting -->
        <div class="col-md-8 d-md-flex">
            <div class="card shadow-sm flex-fill">
                <div class="card-header"><strong>Budgeting (@CurrentMonthName @CurrentYear)</strong></div>
                <div class="card-body px-0 pe-3">
                    @{
                        var incomeBudgets = BudgetSummaries.Where(b => b.Category != null && b.Category.IsIncome).OrderBy(b => b.Category!.Name).ToList();
                        var expenseBudgets = BudgetSummaries.Where(b => b.Category != null && !b.Category.IsIncome).OrderBy(b => b.Category!.Name).ToList();
                    }
                    
                    @if (BudgetSummaries.Count == 0)
                    {
                        <div class="p-3">No budgets added. <a href="/budgets">Create a budget</a>.</div>
                    }
                    else
                    {
                        @if (incomeBudgets.Count > 0)
                        {
                            <div class="mb-4">
                                <caption class="h6 px-3 mb-2 fw-bold w-100">Income Categories</caption>
                                <table class="table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Category</th>
                                            <th class="text-end">Budgeted</th>
                                            <th class="text-end">Earned</th>
                                            <th class="text-end">Remaining</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var b in incomeBudgets)
                                        {
                                            // Income: red if Remaining > 0 (haven't reached target), green if Remaining <= 0 (reached/exceeded target)
                                            string remainingColorClass = b.Remaining <= 0 ? "text-success" : "text-danger";
                                            
                                            <tr>
                                                <td>@b.Category!.Name</td>
                                                <td class="text-end">@b.Budgeted.ToString("C")</td>
                                                <td class="text-end">@b.Spent.ToString("C")</td>
                                                <td class="text-end @remainingColorClass">
                                                    @b.Remaining.ToString("C")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        
                        @if (expenseBudgets.Count > 0)
                        {
                            <div>
                                <caption class="h6 px-3 mb-2 fw-bold w-100">Expense Categories</caption>
                                <table class="table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Category</th>
                                            <th class="text-end">Budgeted</th>
                                            <th class="text-end">Spent</th>
                                            <th class="text-end">Remaining</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var b in expenseBudgets)
                                        {
                                            // Expense: green if Remaining >= 0 (within budget), red if Remaining < 0 (over budget)
                                            string remainingColorClass = b.Remaining >= 0 ? "text-success" : "text-danger";
                                            
                                            <tr>
                                                <td>@b.Category!.Name</td>
                                                <td class="text-end">@b.Budgeted.ToString("C")</td>
                                                <td class="text-end">@b.Spent.ToString("C")</td>
                                                <td class="text-end @remainingColorClass">
                                                    @b.Remaining.ToString("C")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Net Worth + Quick Add (right side) -->
        <div class="col-md-4 d-md-flex">
            <div class="d-flex flex-column w-100" style="gap: 1rem;">
                <!-- Net worth quick estimate -->
                <div class="card shadow-sm flex-fill">
                    <div class="card-header"><strong>Current Net Worth</strong></div>
                    <div class="card-body">
                        <strong>Total Assets</strong>
                        <div>
                            $@TotalAssets
                        </div>

                        <div class="mb-4"></div>

                        <strong>Total Debts</strong>
                        <div>
                            $@TotalDebts
                        </div>
                        
                        <br/>
                        <strong>Net Worth:</strong>
                        <span class="fw-bold @(NetWorth >= 0 ? "text-success" : "text-danger")">
                            @NetWorth.ToString("C")
                        </span>
                    </div>
                </div>

                <!-- Quick Add Transaction -->
                <div class="card shadow-sm flex-fill">
                    <div class="card-header"><strong>Quick Add Transaction</strong></div>
                    <div class="card-body">
                        <EditForm Model="@QuickTransaction" OnValidSubmit="@SaveQuickTransaction">
                            <DataAnnotationsValidator />

                            <label for="quick-transaction-date">Date*</label>
                            <InputDate required aria-required="true" id="quick-transaction-date" class="form-control mb-2" @bind-Value="@QuickTransaction.Date" />

                            <label for="quick-transaction-account">Account*</label>
                            <InputSelect required aria-required="true" id="quick-transaction-account"
                                class="form-select mb-2" @bind-Value="@QuickTransaction.AccountId">
                                <option value="0">-- Select an option --</option>
                                @foreach (var account in UserAccounts)
                                {
                                    <option value="@account.Id">@account.Name</option>
                                }
                            </InputSelect>


                            <label for="quick-transaction-source">Source</label>
                            <InputText class="form-control mb-2" id="quick-transaction-source"
                                placeholder="Merchant, vendor, employer, etc." list="quickSourceList"
                                @bind-Value="@QuickTransaction.Source" />
                            <datalist id="quickSourceList">
                                @foreach (var source in availableSources)
                                {
                                    <option value="@source" />
                                }
                            </datalist>

                            <label for="quick-transaction-category">Category*</label>
                            <InputSelect required aria-required="true" id="quick-transaction-category"
                                class="form-select mb-2" @bind-Value="@QuickTransaction.CategoryId">
                                <option value="0">-- Select a category --</option>
                                @foreach (var category in availableCategories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </InputSelect>

                            <label for="quick-transaction-amount">Amount*</label>
                            <InputNumber required aria-required="true" id="quick-transaction-amount"
                                class="form-control mb-2" @bind-Value="@QuickTransaction.Amount" />

                            <label for="quick-transaction-description">Description</label>
                            <InputText class="form-control mb-2" id="quick-transaction-description"
                                placeholder="Additional notes or details" @bind-Value="@QuickTransaction.Description" />
 
                            @{
                                var isFormValid = QuickTransaction.AccountId > 0 
                                    && QuickTransaction.CategoryId > 0
                                    && QuickTransaction.Amount != 0;

                                var buttonClass = isFormValid ? "btn btn-primary w-100" : "btn btn-secondary w-100";
                            }

                            <button class="@buttonClass button">
                                Add Transaction
                            </button>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Category Breakdown + Daily Trend (with charts) -->
    <div class="row g-3 mb-4 d-md-flex">
        <!-- Category Breakdown + Pie Chart -->
        <div class="col-lg-6 flex-fill">
            <div class="card shadow-sm h-100">
                <div class="card-header"><strong>Spending by Category</strong></div>
                <div class="card-body">
                    @if (CategoryBreakdown.Count == 0)
                    {
                        <p>No expenses yet.</p>
                    }
                    else
                    {
                        <!-- Chart.js pie/doughnut chart -->
                        <canvas id="categoryChart" width="400" height="300"></canvas>

                        <!-- Optional: textual breakdown under the chart -->
                        <hr />
                        @foreach (var c in CategoryBreakdown)
                        {
                            <div class="mb-2">
                                <div class="d-flex justify-content-between">
                                    <span>@c.Category!.Name</span>
                                    <span>@c.Amount.ToString("C") (@c.PercentOfTotal.ToString("0")%)</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-info"
                                         style="width:@c.PercentOfTotal.ToString("0")%"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Daily Trend + Line Chart -->
        <div class="col-lg-6 d-md-flex">
            <div class="card shadow-sm flex-fill">
                <div class="card-header"><strong>Daily Income & Expense Trend</strong></div>
                <div class="card-body">
                    @if (DaySummaries.Count == 0)
                    {
                        <p>No activity yet.</p>
                    }
                    else
                    {
                        <!-- Chart.js line chart -->
                        <canvas id="dailyTrendChart" width="400" height="300"></canvas>

                        <!-- Optional: keep the small table under the chart -->
                        <hr />
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Day</th>
                                    <th>Income</th>
                                    <th>Expenses</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in DaySummaries)
                                {
                                    <tr>
                                        <td>@d.Day</td>
                                        <td class="text-success">@d.Income.ToString("C")</td>
                                        <td class="text-danger">@d.Expenses.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="row g-3 mb-4 d-md-flex">
        <div class="col-lg-12 d-md-flex">
            <div class="card shadow-sm flex-fill">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Recent Transactions</strong>
                    <a href="/accounts" class="btn btn-sm btn-primary">View all</a>
                </div>
                <div class="card-body">
                    <label for="search">Search</label>
                    <input class="form-control mb-2" id="search"
                           placeholder="Search..."
                           @bind="TransactionSearch" />

                    @if (FilteredTransactions.Count == 0)
                    {
                        <p>No matching transactions.</p>
                    }
                    else
                    {
                        <div class="container-fluid mb-2">
                            <div class="row border-bottom py-2 fw-bold">
                                <div class="col-md-2 col-3">Account</div>
                                <div class="col-md-1 col-3">Date</div>
                                <div class="col-md-2 col-4">Source</div>
                                <div class="col-md-2 col-4">Category</div>
                                <div class="col-md-2 col-5 text-end">Amount</div>
                                <div class="col-md-auto col-12 text-end ms-md-auto">Detail</div>
                            </div>
                        </div>
                        @foreach (var t in FilteredTransactions)
                        {
                            <TransactionDisplay User="@user" Transaction="@t" Categories="@availableCategories" Accounts="@UserAccounts" Callback="@OnTransactionDisplayChanged" HideDescription="true" />
                        }
                        @* <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Description</th>
                                    <th>Category</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in FilteredTransactions)
                                {
                                    <tr>
                                        <td>@t.Date.ToString("yyyy-MM-dd")</td>
                                        <td>@(t.Description ?? "(No description)")</td>
                                        <td>@t.Category!.Name</td>
                                        <td class="text-end @(t.Category != null && !t.Category.IsIncome ? "text-danger" : "text-success")">
                                            @t.Amount.ToString("C")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table> *@
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private User? user;

    private bool IsLoading = true;
    private string? ErrorMessage;

    // KPI Data
    private decimal TotalIncome;
    private decimal TotalExpensesRaw;
    private decimal TotalExpensesDisplay => Math.Abs(TotalExpensesRaw);
    private decimal Balance => TotalIncome + TotalExpensesRaw;
    
    // Budget totals for progress bars
    private decimal TotalBudgetedIncome;
    private decimal TotalBudgetedExpenses;

    // Debts
    private decimal TotalDebtBalance;

    // Date context
    private int CurrentMonth;
    private int CurrentYear;
    private string CurrentMonthName => new DateTime(CurrentYear, CurrentMonth, 1).ToString("MMMM");

    // For last month comparison
    private decimal LastMonthIncome;
    private decimal LastMonthExpensesRaw;
    private decimal LastMonthExpensesDisplay => Math.Abs(LastMonthExpensesRaw);

    private decimal IncomeChange => TotalIncome - LastMonthIncome;
    private decimal ExpenseChange => TotalExpensesDisplay - LastMonthExpensesDisplay;

    // Dashboard data
    private List<BudgetSummary> BudgetSummaries = new();
    private List<CategorySpendingSummary> CategoryBreakdown = new();
    private List<DaySummary> DaySummaries = new();
    private List<UserTransaction> RecentTransactions = new();

    // Quick Add
    private UserTransaction QuickTransaction = new();
    private List<Category> availableCategories = new();
    private List<string> availableSources = new();

    // Search for recent transactions
    private string TransactionSearch = string.Empty;
    private List<UserTransaction> FilteredTransactions =>
        string.IsNullOrWhiteSpace(TransactionSearch)
            ? RecentTransactions
            : RecentTransactions.Where(t =>
                   (t.Description?.Contains(TransactionSearch, StringComparison.OrdinalIgnoreCase) ?? false) ||
                   (t.Source?.Contains(TransactionSearch, StringComparison.OrdinalIgnoreCase) ?? false) ||
                   (t.Category?.Name.Contains(TransactionSearch, StringComparison.OrdinalIgnoreCase) ?? false) ||
                   (t.Account?.Name.Contains(TransactionSearch, StringComparison.OrdinalIgnoreCase) ?? false) ||
                   t.Amount.ToString().Contains(TransactionSearch))
              .ToList();

    // Manual net worth inputs
    private double TotalAssets => Context.Accounts.Where( 
            t => t.UserId == user!.Id 
            && (t.Type == AccountType.Checking 
            || t.Type == AccountType.Cash 
            || t.Type == AccountType.Retirement 
            || t.Type == AccountType.Savings)).Sum(t => (double)t.CurrentBalance);

    private double TotalDebts => Context.Accounts.Where( 
            t => t.UserId == user!.Id 
            && (t.Type == AccountType.Loan 
            || t.Type == AccountType.CreditCard)).Sum(t => (double)t.CurrentBalance);
            
    private double NetWorth => TotalAssets - TotalDebts;

    // Motivational message
    private string MotivationalMessage { get; set; } = string.Empty;

    // Get list of user accounts
    private List<Account> UserAccounts = new List<Account>();

    private async Task LoadUserAccounts()
    {
        var accounts = await Context.Accounts.Where(t => t.UserId == user!.Id).ToListAsync();
        UserAccounts = accounts;
    }
    
    // ----- Lifecycle -----

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var today = DateTime.Today;
            CurrentMonth = today.Month;
            CurrentYear = today.Year;

            var auth = await AuthProvider.GetAuthenticationStateAsync();
            user = await UserManager.GetUserAsync(auth.User);

            if (user == null)
            {
                IsLoading = false;
                return;
            }

            await LoadUserAccounts();
            await LoadCategoriesAsync();
            await LoadSourcesAsync();
            await LoadDashboard();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Refresh categories when navigating to this page to ensure newly added categories are available
        if (user is not null && !IsLoading)
        {
            await LoadCategoriesAsync();
        }
    }

    private async Task LoadCategoriesAsync()
    {
        if (user is null) return;

        try
        {
            // Load default categories (UserId is null) and user's custom categories
            availableCategories = await Context.Categories
                .Where(c => c.UserId == null || c.UserId == user.Id)
                .OrderBy(c => c.Name)
                .ToListAsync();
        }
        catch (Exception)
        {
            // If Categories table doesn't exist yet, use empty list
            availableCategories = new List<Category>();
        }
    }

    private async Task LoadSourcesAsync()
    {
        if (user is null) return;

        try
        {
            // Get unique source values from existing transactions for this user
            availableSources = await Context.UserTransactions
                .Where(t => t.UserId == user.Id && !string.IsNullOrWhiteSpace(t.Source))
                .Select(t => t.Source!)
                .Distinct()
                .OrderBy(s => s)
                .ToListAsync();
        }
        catch
        {
            availableSources = new List<string>();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && user != null)
        {
            await RenderChartsAsync();
        }
    }

    // ----- JSInterop for charts -----

    private async Task RenderChartsAsync()
    {
        // Category pie chart
        if (CategoryBreakdown?.Count > 0)
        {
            var labels = CategoryBreakdown.Select(c => c.Category!.Name).ToArray();
            var values = CategoryBreakdown.Select(c => c.Amount).ToArray();

            await JS.InvokeVoidAsync("renderCategoryChart", labels, values);
        }

        // Daily line chart
        if (DaySummaries?.Count > 0)
        {
            var days = DaySummaries.Select(d => d.Day).ToArray();
            var incomes = DaySummaries.Select(d => d.Income).ToArray();
            var expenses = DaySummaries.Select(d => d.Expenses).ToArray();

            await JS.InvokeVoidAsync("renderDailyTrendChart", days, incomes, expenses);
        }

        
    }

    // ----- Data loading -----

    private async Task LoadDashboard()
    {
        if (user == null) return;

        var transactions = await Context.UserTransactions
            .Include(t => t.Category)
            .Include(t => t.Account)
            .Where(t => t.UserId == user.Id &&
                        t.Date.Month == CurrentMonth &&
                        t.Date.Year == CurrentYear)
            .ToListAsync();

        var incomes = await Context.Incomes
            .Where(i => i.UserId == user.Id &&
                        i.Date.Month == CurrentMonth &&
                        i.Date.Year == CurrentYear)
            .ToListAsync();

        var budgets = await Context.Budgets
            .Include(b => b.Category)
            .Where(b => b.UserId == user.Id &&
                        b.Month == CurrentMonth &&
                        b.Year == CurrentYear)
            .ToListAsync();

        var debts = await Context.Debts
            .Where(d => d.UserId == user.Id)
            .ToListAsync();

        TotalDebtBalance = debts.Sum(d => d.CurrentBalance);

        // Income & expenses - use category type, not amount sign
        TotalIncome = incomes.Sum(i => i.Amount) +
                      transactions.Where(t => t.Category != null && t.Category.IsIncome).Sum(t => t.Amount);

        TotalExpensesRaw = -transactions.Where(t => t.Category != null && !t.Category.IsIncome).Sum(t => t.Amount);

        // Calculate total budgeted amounts
        TotalBudgetedIncome = budgets
            .Where(b => b.Category != null && b.Category.IsIncome)
            .Sum(b => b.MonthlyLimit);
        
        TotalBudgetedExpenses = budgets
            .Where(b => b.Category != null && !b.Category.IsIncome)
            .Sum(b => b.MonthlyLimit);

        // Derived data
        BuildBudgetSummaries(budgets, transactions);
        BuildCategoryBreakdown(transactions);
        BuildDaySummaries(transactions, incomes);
        await LoadLastMonthComparison();
        BuildMotivationalMessage();

        // Recent transactions - get from all accounts, not just current month
        RecentTransactions = await Context.UserTransactions
            .Include(t => t.Category)
            .Include(t => t.Account)
            .Where(t => t.UserId == user.Id)
            .OrderByDescending(t => t.Date)
            .ThenByDescending(t => t.Id)
            .Take(20)
            .ToListAsync();

        QuickTransaction = new UserTransaction
        {
            UserId = user.Id,
            AccountId = QuickTransaction.AccountId,
            Date = DateOnly.FromDateTime(DateTime.Today),
        };
    }

    private void BuildBudgetSummaries(List<Budget> budgets, List<UserTransaction> transactions)
    {
        BudgetSummaries = budgets.Select(b =>
        {
            decimal amount = 0;
            
            if (b.Category != null && b.Category.IsIncome)
            {
                // For income budgets, sum all income transactions in that category
                amount = transactions
                    .Where(t => t.CategoryId == b.CategoryId && t.Category != null && t.Category.IsIncome)
                    .Sum(t => t.Amount);
            }
            else
            {
                // For expense budgets, sum all expense transactions in that category
                amount = transactions
                    .Where(t => t.CategoryId == b.CategoryId && t.Category != null && !t.Category.IsIncome)
                    .Sum(t => t.Amount);
            }

            return new BudgetSummary
            {
                Category = b.Category,
                Budgeted = b.MonthlyLimit,
                Spent = amount,
                Remaining = b.MonthlyLimit - amount
            };
        }).ToList();
    }

    private void BuildCategoryBreakdown(List<UserTransaction> transactions)
    {
        var expenses = transactions.Where(t => t.Category != null && !t.Category.IsIncome).ToList();

        if (!expenses.Any())
        {
            CategoryBreakdown.Clear();
            return;
        }

        var total = Math.Abs(expenses.Sum(t => t.Amount));

        CategoryBreakdown = expenses
        .GroupBy(t => t.Category)
        .Select(g =>
        {
            var amount = Math.Abs(g.Sum(x => x.Amount));
            return new CategorySpendingSummary
            {
                Category = g.Key,
                Amount = amount,
                PercentOfTotal = (amount / total) * 100m
            };
        })
        .OrderByDescending(c => c.Amount)
        .ToList();
    }

    private void BuildDaySummaries(List<UserTransaction> transactions, List<Income> incomes)
    {
        var map = new Dictionary<int, DaySummary>();

        foreach (var inc in incomes)
        {
            var day = inc.Date.Day;
            if (!map.ContainsKey(day)) map[day] = new DaySummary { Day = day };
            map[day].Income += inc.Amount;
        }

        foreach (var t in transactions)
        {
            var day = t.Date.Day;
            if (!map.ContainsKey(day)) map[day] = new DaySummary { Day = day };

            if (t.Category != null && t.Category.IsIncome)
                map[day].Income += t.Amount;
            else if (t.Category != null && !t.Category.IsIncome)
                map[day].Expenses += t.Amount;
        }

        DaySummaries = map.Values.OrderBy(x => x.Day).ToList();
    }

    private async Task LoadLastMonthComparison()
    {
        var prev = new DateTime(CurrentYear, CurrentMonth, 1).AddMonths(-1);

        var transactions = await Context.UserTransactions
            .Include(t => t.Category)
            .Where(t => t.UserId == user!.Id &&
                        t.Date.Month == prev.Month &&
                        t.Date.Year == prev.Year)
            .ToListAsync();

        var incomes = await Context.Incomes
            .Where(i => i.UserId == user!.Id &&
                        i.Date.Month == prev.Month &&
                        i.Date.Year == prev.Year)
            .ToListAsync();

        LastMonthIncome = incomes.Sum(i => i.Amount) +
                          transactions.Where(t => t.Category != null && t.Category.IsIncome).Sum(t => t.Amount);

        LastMonthExpensesRaw = -transactions.Where(t => t.Category != null && !t.Category.IsIncome).Sum(t => t.Amount);
    }

    private void BuildMotivationalMessage()
    {
        if (TotalIncome == 0 && TotalExpensesRaw == 0)
        {
            MotivationalMessage = "Welcome! Add your first income or expense to get started.";
            return;
        }

        if (Balance > 0)
        {
            MotivationalMessage = "Great job! You're spending less than you earn!";
        }
        else if (Balance == 0)
        {
            MotivationalMessage = "You're breaking even. A little adjustment can help you save more.";
        }
        else
        {
            MotivationalMessage = "You're spending more than you're earning. Review your budget categories!";
        }
    }

    // ----- Actions -----

    private async Task SaveQuickTransaction()
    {
        ErrorMessage = null;
        
        try
        {
            // Validate required fields
            if (QuickTransaction.CategoryId == 0)
            {
                // Try to get CategoryId from Category navigation property
                if (QuickTransaction.Category != null)
                {
                    QuickTransaction.CategoryId = QuickTransaction.Category.Id;
                }
                else
                {
                    ErrorMessage = "Please select a category.";
                    return;
                }
            }

            if (QuickTransaction.AccountId == 0)
            {
                ErrorMessage = "Please select an account.";
                return;
            }

            // Verify the category exists
            var categoryExists = await Context.Categories
                .AnyAsync(c => c.Id == QuickTransaction.CategoryId);
            
            if (!categoryExists)
            {
                ErrorMessage = "Selected category does not exist. Please select a valid category.";
                return;
            }

            // Verify the account exists and belongs to the user
            var accountExists = await Context.Accounts
                .AnyAsync(a => a.Id == QuickTransaction.AccountId && a.UserId == user!.Id);
            
            if (!accountExists)
            {
                ErrorMessage = "Selected account does not exist. Please select a valid account.";
                return;
            }

            // Create new transaction entity without navigation properties to avoid tracking conflicts
            var newTransaction = new UserTransaction
            {
                UserId = user!.Id,
                AccountId = QuickTransaction.AccountId,
                CategoryId = QuickTransaction.CategoryId,
                Date = QuickTransaction.Date,
                Source = QuickTransaction.Source,
                Description = QuickTransaction.Description,
                Amount = QuickTransaction.Amount
            };

            Context.UserTransactions.Add(newTransaction);
            await Context.SaveChangesAsync();
            
            ErrorMessage = null; // Clear any previous errors
            await LoadDashboard();
            await LoadSourcesAsync(); // Reload sources to include any new one

            // After data reload, charts will be re-rendered on next render pass
            await RenderChartsAsync();
        }
        catch (DbUpdateException dbEx)
        {
            var innerEx = dbEx.InnerException?.Message ?? dbEx.Message;
            ErrorMessage = $"Database error: {innerEx}";
            System.Diagnostics.Debug.WriteLine($"Database error: {innerEx}");
        }
        catch (Exception ex)
        {
            var innerEx = ex.InnerException?.Message ?? ex.Message;
            ErrorMessage = $"Error saving transaction: {innerEx}";
            System.Diagnostics.Debug.WriteLine($"Error: {innerEx}");
        }
    }

    // Refresh page when quick transaction is modified
    private async Task OnTransactionDisplayChanged()
    {
        await LoadDashboard();
        await LoadSourcesAsync(); // Reload sources to include any new ones

        RecentTransactions = FilteredTransactions
        .OrderByDescending(t => t.Date)
        .Take(20)
        .ToList();

        StateHasChanged();
        return;
    }

